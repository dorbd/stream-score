# TMDb API (required) — https://www.themoviedb.org/settings/api
# Use a v3 API key (not the v4 read access token).
TMDB_API_KEY=your_tmdb_v3_api_key_here

# OMDb API (optional, recommended) — https://www.omdbapi.com/apikey.aspx
# Provides IMDb, Rotten Tomatoes, and Metacritic scores. Free tier = 1000/day.
# If unset the app still works; RT/Metacritic columns just show N/A.
OMDB_API_KEY=your_omdb_api_key_here

# Optional: TMDb region used for watch-provider lookups (defaults to US).
NEXT_PUBLIC_TMDB_REGION=US
